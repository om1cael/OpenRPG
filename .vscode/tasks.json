{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-normal",
			"type": "shell",
			"command": "${workspaceRoot}/qawno/pawncc",
			"runOptions": {
				"instanceLimit": 1,
			},
			"args": [
				"${workspaceRoot}/gamemodes/rpg.pwn",
				"-Dgamemodes",
				"'-;+'",
				"'-(+'",
				"'-d3'",
				"-Z+"
			],
			"options": {
				"env": {
					"LD_LIBRARY_PATH": "${workspaceRoot}/qawno:${env:LD_LIBRARY_PATH}"
				}
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": false,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": {
				"owner": "pawn",
				"fileLocation": [
					"autoDetect",
					"${workspaceRoot}/gamemodes"
				],
				"pattern": {
					"regexp": "^(.*?)\\(([0-9]*)[- 0-9]*\\) \\: (fatal error|error|warning) [0-9]*\\: (.*)$",
					"file": 1,
					"location": 2,
					"severity": 3,
					"message": 4
				}
			}
		}
	],
}